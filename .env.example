# ─── RESONANCE Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your real values before running Docker.
# NEVER commit .env to git.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=neuro_onco_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# ─── Backend / JWT ────────────────────────────────────────────────────────────
# Generate a strong random string, e.g.:  openssl rand -hex 64
JWT_SECRET=change_me_jwt_secret_at_least_64_chars_long
JWT_EXPIRE=7d

# ─── AES-256-GCM Encryption ───────────────────────────────────────────────────
# Must be exactly 64 hex characters (32 bytes)
# Generate with:  openssl rand -hex 32
AES_SECRET_KEY=change_me_64_hex_chars_aes_key_here_0000000000000000000000000000

# ─── Google Gemini API ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Ollama Configuration ─────────────────────────────────────────────────────
OLLAMA_MODEL=phi3:14b

# ─── GitHub Models (Optional Fallback) ────────────────────────────────────────
GITHUB_TOKEN=your_github_pat_here
GITHUB_MODEL=gpt-4o

# ─── Google Gemini API ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8000
